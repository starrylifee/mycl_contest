rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // OCR용 이미지: 누구나 업로드, 서버만 읽기 (Admin SDK)
    match /ocr/{allPaths=**} {
      allow write: if request.resource.size < 10 * 1024 * 1024  // 10MB 제한
                   && request.resource.contentType.matches('image/.*');
      allow read: if false; // 서버사이드(Admin SDK)에서만 접근
    }
  }
}
